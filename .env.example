# ---------------------------------------------------------------------------
# Supplier Intelligence API - configuration
# Copy to .env and fill in. Every value below has a working default except
# ANTHROPIC_API_KEY.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# PostgreSQL is the target datastore. If this URL is unreachable at startup the
# app logs a loud warning and falls back to ./data/supplier_intel.db (SQLite)
# so the demo still runs. Bring up Postgres with: docker compose up -d
DATABASE_URL=postgresql+asyncpg://supplier:supplier@localhost:5432/supplier_intel

# Set to false to hard-fail instead of falling back to SQLite.
ALLOW_SQLITE_FALLBACK=true

# --- Claude (report generation) ---------------------------------------------
# Without a key the investigation still completes; the agent_summary section is
# generated deterministically from the evidence instead of by Claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_EFFORT=high

# --- Required outbound identification ---------------------------------------
# SEC EDGAR *requires* a real contact address in the User-Agent or it 403s.
USER_AGENT=SupplierIntelligenceAPI/0.1 (contact@example.com)

# --- Embeddings -------------------------------------------------------------
# openai -> text-embedding-3-large   (needs OPENAI_API_KEY)
# local  -> sentence-transformers/all-MiniLM-L6-v2
# hashed -> pure-python char-ngram TF-IDF (no install, always available)
# auto   -> openai, then local, then hashed
EMBEDDING_BACKEND=auto
OPENAI_API_KEY=

# --- Optional source credentials --------------------------------------------
# CourtListener throttles hard without a token; free at courtlistener.com.
COURTLISTENER_API_TOKEN=

# --- Tuning -----------------------------------------------------------------
HTTP_CACHE_TTL_HOURS=24
OFAC_REFRESH_HOURS=24
GDELT_MONTHS=24
INVESTIGATION_TIMEOUT_SECONDS=60
